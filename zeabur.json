{
  "build": {
    "command": "npm ci",
    "development": "npm run dev",
    "framework": "node"
  },
  "env": {
    "NODE_ENV": "production",
    "GITHUB_TOKEN": {
      "description": "GitHub Personal Access Token",
      "required": false
    },
    "GITHUB_REPO": {
      "description": "GitHub repository (default: asi76/crosstraining)",
      "required": false
    }
  }
}
